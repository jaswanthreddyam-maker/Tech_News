# ==============================================================================
# Tech News Today - Centralized Configuration Environment File
# ==============================================================================

# Core Application Settings
PROJECT_NAME="Tech News Today"
ENV=development
APP_ENV=development
DEBUG=true
API_V1_STR=/api/v1
SECRET_KEY=your_secret_key_here_change_me_in_production_32_chars_long

# CORS Setup
BACKEND_CORS_ORIGINS=["http://localhost", "http://localhost:3000", "http://127.0.0.1:3000"]

# PostgreSQL Configuration (Exclusively Postgres, no SQLite fallback)
POSTGRES_SERVER=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_pass
POSTGRES_DB=tech_news_today
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres_secure_pass@db:5432/tech_news_today

# Redis Configuration (Cache, locking, queue broker)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# AI Provider Settings (Insert your live key here for Phase 3 onwards)
OPENAI_API_KEY=sk-placeholder-openai-api-key
AI_PROVIDER=disabled
MAX_AI_RETRIES=3

# Scraper Politeness Policies
SCRAPER_RATE_LIMIT_DELAY=2.0
USER_AGENT="TechNewsTodayBot/1.0 (+http://localhost/bot)"
