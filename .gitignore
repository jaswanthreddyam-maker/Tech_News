storage/
*.py[cod]
*$py.class
*.so
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
.egg
.venv
venv
ENV/
codebase.zip
*.zip
node_modules/
.next/
backend/celerybeat-schedule
backend/celerybeat-schedule.*
# Node / NextJS files
node_modules/
/frontend/.next/
/frontend/out/
/frontend/build/
.npm
/frontend/npm-debug.log*
/frontend/yarn-debug.log*
/frontend/yarn-error.log*

# Environment files (Never commit secrets!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# Docker data stores & persistent volumes
.docker-volumes/
postgres_data/
redis_data/
/database/data/

# Application Rotating Logs
backend/logs/
/logs/
*.log

# OS & Editor specific files
.DS_Store
Thumbs.db
